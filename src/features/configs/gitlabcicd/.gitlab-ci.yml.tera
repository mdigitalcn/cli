image: node:22-alpine

stages:
  - build

cache:
  key:
    files:
      - pnpm-lock.yaml
  paths:
    - node_modules/

before_script:
  - corepack enable
  - pnpm install --frozen-lockfile

build:
  stage: build
  script:
{% if project.has_typescript %}    - pnpm tsc --noEmit
{% endif %}    - pnpm lint
    - pnpm build
  artifacts:
    paths:
{% if project.has_nextjs %}      - .next/
{% else %}      - dist/
{% endif %}    expire_in: 1 day
  only:
    - main
    - merge_requests
